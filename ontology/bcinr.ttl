@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix bcinr: <http://bcinr.rs/ontology/> .

# ============================================================================
# Classes
# ============================================================================

bcinr:AlgorithmFamily a rdfs:Class ;
  rdfs:label "Algorithm Family" ;
  rdfs:comment "A named family of related branchless algorithms" .

bcinr:ApiSymbol a rdfs:Class ;
  rdfs:label "API Symbol" ;
  rdfs:comment "A function or type exposed in the public API" .

# ============================================================================
# Properties
# ============================================================================

bcinr:id a rdf:Property ;
  rdfs:label "ID" ;
  rdfs:comment "Lowercase, underscore-separated identifier" .

bcinr:label a rdf:Property ;
  rdfs:label "Label" ;
  rdfs:comment "Human-readable name" .

bcinr:description a rdf:Property ;
  rdfs:label "Description" ;
  rdfs:comment "Detailed explanation" .

bcinr:ofFamily a rdf:Property ;
  rdfs:label "Of Family" ;
  rdfs:comment "Reference to the containing algorithm family" .

bcinr:name a rdf:Property ;
  rdfs:label "Name" ;
  rdfs:comment "Symbol name (function or type)" .

# ============================================================================
# Instances: Algorithm Families (12 total)
# ============================================================================

<http://bcinr.rs/instance/family/mask> a bcinr:AlgorithmFamily ;
  bcinr:id "mask" ;
  bcinr:label "Mask Calculus" ;
  bcinr:description "Bitwise mask selection: (mask & a) | (~mask & b)" .

<http://bcinr.rs/instance/family/int> a bcinr:AlgorithmFamily ;
  bcinr:id "int" ;
  bcinr:label "Integer Bitwise" ;
  bcinr:description "Integer bit manipulation without branches" .

<http://bcinr.rs/instance/family/fix> a bcinr:AlgorithmFamily ;
  bcinr:id "fix" ;
  bcinr:label "Saturation Arithmetic" ;
  bcinr:description "Fixed-point and saturation arithmetic" .

<http://bcinr.rs/instance/family/network> a bcinr:AlgorithmFamily ;
  bcinr:id "network" ;
  bcinr:label "Compare-Exchange Networks" ;
  bcinr:description "Bitonic and AKS sorting networks" .

<http://bcinr.rs/instance/family/bitset> a bcinr:AlgorithmFamily ;
  bcinr:id "bitset" ;
  bcinr:label "Bitset Algebra" ;
  bcinr:description "Bitset operations: rank, select, set, clear" .

<http://bcinr.rs/instance/family/scan> a bcinr:AlgorithmFamily ;
  bcinr:id "scan" ;
  bcinr:label "Byte/Word Scanning" ;
  bcinr:description "Scanning and searching within byte/word sequences" .

<http://bcinr.rs/instance/family/utf8> a bcinr:AlgorithmFamily ;
  bcinr:id "utf8" ;
  bcinr:label "UTF-8 Calculus" ;
  bcinr:description "Byte-level UTF-8 validation and analysis" .

<http://bcinr.rs/instance/family/parse> a bcinr:AlgorithmFamily ;
  bcinr:id "parse" ;
  bcinr:label "Parsing Primitives" ;
  bcinr:description "Number parsing and format recognition" .

<http://bcinr.rs/instance/family/dfa> a bcinr:AlgorithmFamily ;
  bcinr:id "dfa" ;
  bcinr:label "Table-Driven Automata" ;
  bcinr:description "Finite automata via lookup tables" .

<http://bcinr.rs/instance/family/reduce> a bcinr:AlgorithmFamily ;
  bcinr:id "reduce" ;
  bcinr:label "SWAR Reductions" ;
  bcinr:description "SIMD Within A Register: horizontal reductions" .

<http://bcinr.rs/instance/family/sketch> a bcinr:AlgorithmFamily ;
  bcinr:id "sketch" ;
  bcinr:label "Probabilistic Sketches" ;
  bcinr:description "Hashing and probabilistic data structures" .

<http://bcinr.rs/instance/family/simd> a bcinr:AlgorithmFamily ;
  bcinr:id "simd" ;
  bcinr:label "SIMD Primitives" ;
  bcinr:description "SIMD vector operations (128/256-bit)" .

